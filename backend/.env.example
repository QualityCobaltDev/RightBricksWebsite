NODE_ENV=development
APP_NAME=RightBricks
APP_URL=http://localhost:3000
CANONICAL_BASE_URL=http://localhost:3000

DATABASE_URL=postgresql://rightbricks:change_me@127.0.0.1:5432/rightbricks?schema=public
DIRECT_URL=postgresql://rightbricks:change_me@127.0.0.1:5432/rightbricks?schema=public

JWT_ISSUER=rightbricks.local
JWT_AUDIENCE=rightbricks.local
JWT_SECRET=replace-with-64-char-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

BCRYPT_ROUNDS=12

SMTP_HOST=mail.example.local
SMTP_PORT=587
SMTP_USER=mailer
SMTP_PASS=change_me
SMTP_FROM=noreply@rightbricks.online

S3_ENDPOINT=https://s3.example.local
S3_REGION=ap-southeast-1
S3_BUCKET=rightbricks-prod-media
S3_ACCESS_KEY=change_me
S3_SECRET_KEY=change_me

SEARCH_PROVIDER=opensearch
SEARCH_URL=http://127.0.0.1:9200
SEARCH_INDEX_LISTINGS=rightbricks_listings_v1
MAP_STYLE_URL=https://maps.rightbricks.online/styles/basic
MAP_DEFAULT_LAT=11.5564
MAP_DEFAULT_LNG=104.9282
MAP_DEFAULT_ZOOM=12

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

LOG_LEVEL=info
