generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DEACTIVATED
}

enum RoleCode {
  SUPER_ADMIN
  ADMIN
  MODERATOR
  SUPPORT
  CONTENT_EDITOR
  AGENT
  AGENCY_ADMIN
  DEVELOPER_ADMIN
  OWNER
  LANDLORD
  SEEKER
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OrganizationType {
  AGENCY
  DEVELOPER
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  LEFT
}

enum ListingType {
  SALE
  RENT
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  CHANGES_REQUESTED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ModerationDecision {
  APPROVED
  REJECTED
  NEEDS_CHANGES
  ESCALATED
}

enum PropertyType {
  APARTMENT
  CONDO
  VILLA
  HOUSE
  SHOPHOUSE
  OFFICE
  RETAIL
  LAND
  WAREHOUSE
  FACTORY
  HOTEL
  OTHER
}

enum FurnishingLevel {
  UNFURNISHED
  PARTIALLY_FURNISHED
  FULLY_FURNISHED
}

enum TenureType {
  FREEHOLD
  LEASEHOLD
  STRATA_TITLE
  SOFT_TITLE
  HARD_TITLE
  OTHER
}

enum PricePeriod {
  TOTAL
  MONTHLY
  WEEKLY
  DAILY
}

enum InquiryStatus {
  NEW
  ASSIGNED
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CLOSED
  SPAM
}

enum InquirySource {
  LISTING_DETAIL
  PROJECT_DETAIL
  CONTACT_FORM
  PHONE_CALL
  WHATSAPP
  MANUAL_ADMIN
}

enum MediaType {
  IMAGE
  VIDEO
  FLOOR_PLAN
  DOCUMENT
}

enum PublishChannel {
  WEBSITE
  PORTAL
  API
}

enum ArticleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum LocaleCode {
  EN
  KM
}

enum AuditActorType {
  USER
  SYSTEM
  JOB
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ViewingRequestStatus {
  PENDING
  CONFIRMED
  RESCHEDULED
  COMPLETED
  CANCELED
}

enum MessageThreadStatus {
  OPEN
  ARCHIVED
  BLOCKED
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique @db.Citext
  passwordHash          String?
  phoneE164             String?             @unique
  status                UserStatus          @default(PENDING_VERIFICATION)
  verificationStatus    VerificationStatus  @default(UNVERIFIED)
  firstName             String?
  lastName              String?
  preferredLocale       LocaleCode          @default(EN)
  avatarUrl             String?
  lastLoginAt           DateTime?
  emailVerifiedAt       DateTime?
  phoneVerifiedAt       DateTime?
  acceptedTermsAt       DateTime?
  acceptedPrivacyAt     DateTime?
  marketingConsentAt    DateTime?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  roles                 UserRole[]
  sessions              Session[]
  memberships           OrganizationMember[]
  agentProfile          AgentProfile?
  ownerProfile          OwnerProfile?
  seekerProfile         SeekerProfile?
  listingsOwned         Listing[]            @relation("OwnerListings")
  listingsCreated       Listing[]            @relation("CreatorListings")
  listingsUpdated       Listing[]            @relation("UpdaterListings")
  inquiriesCreated      Inquiry[]            @relation("InquiryCreatedBy")
  inquiriesAssigned     Inquiry[]            @relation("InquiryAssignedTo")
  savedListings         SavedListing[]
  savedSearches         SavedSearch[]
  searchAlerts          SearchAlert[]
  viewingRequests       ViewingRequest[]     @relation("ViewingRequester")
  viewingAssignments    ViewingRequest[]     @relation("ViewingAgent")
  sentMessages          Message[]            @relation("MessageSender")
  messageParticipantsA  MessageThread[]      @relation("ThreadParticipantA")
  messageParticipantsB  MessageThread[]      @relation("ThreadParticipantB")
  articlesCreated       CmsArticle[]         @relation("ArticleCreatedBy")
  articlesUpdated       CmsArticle[]         @relation("ArticleUpdatedBy")
  moderationActions     ModerationAction[]
  auditLogs             AuditLog[]           @relation("AuditActorUser")
  verificationRequests  VerificationRequest[] @relation("VerificationRequestUser")
  verificationReviewed  VerificationRequest[] @relation("VerificationReviewedBy")
  rolesGranted         UserRole[]           @relation("UserRoleGrantedBy")

  @@index([status, deletedAt])
  @@index([verificationStatus, deletedAt])
  @@index([createdAt])
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @unique
  ipAddress     String?
  userAgent     String?
  expiresAt     DateTime
  revokedAt     DateTime?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model Role {
  id            String    @id @default(cuid())
  code          RoleCode  @unique
  name          String
  description   String?
  isSystem      Boolean   @default(true)

  userRoles     UserRole[]
  permissions   RolePermission[]
}

model Permission {
  id            String           @id @default(cuid())
  code          String           @unique
  description   String?

  roleLinks     RolePermission[]
}

model UserRole {
  id            String   @id @default(cuid())
  userId        String
  roleId        String
  grantedById   String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  grantedBy     User?    @relation("UserRoleGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@unique([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  id            String      @id @default(cuid())
  roleId        String
  permissionId  String

  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Organization {
  id                    String              @id @default(cuid())
  type                  OrganizationType
  status                OrganizationStatus  @default(ACTIVE)
  verificationStatus    VerificationStatus  @default(UNVERIFIED)
  legalName             String
  displayName           String
  slug                  String              @unique
  registrationNumber    String?
  taxId                 String?
  phoneE164             String?
  email                 String?
  websiteUrl            String?
  logoUrl               String?
  descriptionEn         String?
  descriptionKm         String?
  foundedYear           Int?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  members               OrganizationMember[]
  listings              Listing[]
  projects              Project[]
  verificationRequests  VerificationRequest[] @relation("VerificationRequestOrganization")

  @@index([type, status, deletedAt])
  @@index([verificationStatus, deletedAt])
  @@index([displayName])
}

model OrganizationMember {
  id                String            @id @default(cuid())
  organizationId    String
  userId            String
  status            MembershipStatus  @default(ACTIVE)
  title             String?
  isPrimaryContact  Boolean           @default(false)
  joinedAt          DateTime?
  invitedById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, status])
  @@index([organizationId, status])
}

model AgentProfile {
  id                    String              @id @default(cuid())
  userId                String              @unique
  licenseNumber         String?
  bioEn                 String?
  bioKm                 String?
  yearsExperience       Int?
  specialties           String[]
  serviceAreas          String[]
  verificationStatus    VerificationStatus  @default(UNVERIFIED)
  ratingAvg             Decimal?            @db.Decimal(3, 2)
  reviewCount           Int                 @default(0)
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, deletedAt])
}

model OwnerProfile {
  id                    String              @id @default(cuid())
  userId                String              @unique
  ownershipType         String?
  verificationStatus    VerificationStatus  @default(UNVERIFIED)
  notes                 String?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationStatus, deletedAt])
}

model SeekerProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  preferredPropertyTypes PropertyType[]
  minBudgetUsd          Decimal?  @db.Decimal(14, 2)
  maxBudgetUsd          Decimal?  @db.Decimal(14, 2)
  preferredLocations    String[]
  needsParking          Boolean?
  wantsPetFriendly      Boolean?
  moveInDate            DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([moveInDate])
}

model Country {
  id            String   @id @default(cuid())
  iso2          String   @unique
  nameEn        String
  nameKm        String?
  createdAt     DateTime @default(now())

  provinces     Province[]
}

model Province {
  id            String   @id @default(cuid())
  countryId     String
  code          String
  nameEn        String
  nameKm        String?
  slug          String
  createdAt     DateTime @default(now())

  country       Country  @relation(fields: [countryId], references: [id], onDelete: Restrict)
  districts     District[]
  listings      Listing[]
  projects      Project[]

  @@unique([countryId, code])
  @@unique([countryId, slug])
  @@index([nameEn])
}

model District {
  id            String   @id @default(cuid())
  provinceId     String
  code           String
  nameEn         String
  nameKm         String?
  slug           String
  createdAt      DateTime @default(now())

  province       Province  @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  communes       Commune[]
  listings       Listing[]
  projects       Project[]

  @@unique([provinceId, code])
  @@unique([provinceId, slug])
  @@index([nameEn])
}

model Commune {
  id            String    @id @default(cuid())
  districtId     String
  code           String
  nameEn         String
  nameKm         String?
  slug           String
  createdAt      DateTime  @default(now())

  district       District  @relation(fields: [districtId], references: [id], onDelete: Restrict)
  listings       Listing[]
  projects       Project[]

  @@unique([districtId, code])
  @@unique([districtId, slug])
  @@index([nameEn])
}

model Listing {
  id                    String              @id @default(cuid())
  externalRef           String?
  slug                  String              @unique
  listingType           ListingType
  status                ListingStatus       @default(DRAFT)
  publishChannel        PublishChannel      @default(WEBSITE)
  propertyType          PropertyType
  furnishingLevel       FurnishingLevel?
  tenureType            TenureType?
  ownerId               String?
  organizationId        String?
  creatorId             String
  updaterId             String
  provinceId            String
  districtId            String
  communeId             String?
  addressLine1          String
  addressLine2          String?
  postalCode            String?
  latitude              Decimal             @db.Decimal(10, 7)
  longitude             Decimal             @db.Decimal(10, 7)
  mapPrecision          Int                 @default(7)
  bedrooms              Int?
  bathrooms             Int?
  floorAreaSqm          Decimal?            @db.Decimal(12, 2)
  landAreaSqm           Decimal?            @db.Decimal(12, 2)
  floorLevel            Int?
  totalFloors           Int?
  parkingSpaces         Int?
  yearBuilt             Int?
  availableFrom         DateTime?
  isNegotiable          Boolean             @default(false)
  isFeatured            Boolean             @default(false)
  isVerified            Boolean             @default(false)
  priceUsd              Decimal             @db.Decimal(14, 2)
  priceKhrApprox        Decimal?            @db.Decimal(16, 2)
  pricePeriod           PricePeriod         @default(TOTAL)
  maintenanceFeeUsd     Decimal?            @db.Decimal(12, 2)
  youtubeUrl            String?
  virtualTourUrl        String?
  publishedAt           DateTime?
  archivedAt            DateTime?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  owner                 User?               @relation("OwnerListings", fields: [ownerId], references: [id], onDelete: SetNull)
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  creator               User                @relation("CreatorListings", fields: [creatorId], references: [id], onDelete: Restrict)
  updater               User                @relation("UpdaterListings", fields: [updaterId], references: [id], onDelete: Restrict)
  province              Province            @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  district              District            @relation(fields: [districtId], references: [id], onDelete: Restrict)
  commune               Commune?            @relation(fields: [communeId], references: [id], onDelete: SetNull)
  translations          ListingTranslation[]
  media                 ListingMedia[]
  amenityLinks          ListingAmenity[]
  inquiries             Inquiry[]
  savedBy               SavedListing[]
  viewingRequests       ViewingRequest[]
  messageThreads        MessageThread[]
  moderationActions     ModerationAction[]

  @@index([listingType, status, deletedAt])
  @@index([propertyType, status, deletedAt])
  @@index([provinceId, districtId, communeId])
  @@index([priceUsd, status, deletedAt])
  @@index([bedrooms, bathrooms, status])
  @@index([publishedAt])
  @@index([organizationId, status])
  @@index([ownerId, status])
  @@index([latitude, longitude])
}

model ListingTranslation {
  id                String      @id @default(cuid())
  listingId         String
  locale            LocaleCode
  title             String
  description       String
  neighborhoodText  String?
  seoTitle          String?
  seoDescription    String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  listing           Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, locale])
  @@index([locale, title])
}

model Amenity {
  id              String    @id @default(cuid())
  code            String    @unique
  nameEn          String
  nameKm          String?
  category        String?
  isActive        Boolean   @default(true)

  listingLinks    ListingAmenity[]

  @@index([isActive, category])
}

model ListingAmenity {
  id              String    @id @default(cuid())
  listingId       String
  amenityId       String
  createdAt       DateTime  @default(now())

  listing         Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  amenity         Amenity   @relation(fields: [amenityId], references: [id], onDelete: Restrict)

  @@unique([listingId, amenityId])
  @@index([amenityId, listingId])
}

model ListingMedia {
  id                String     @id @default(cuid())
  listingId         String
  mediaType         MediaType
  storageKey        String     @unique
  publicUrl         String
  mimeType          String?
  width             Int?
  height            Int?
  durationSeconds   Int?
  fileSizeBytes     BigInt?
  altTextEn         String?
  altTextKm         String?
  displayOrder      Int        @default(0)
  isCover           Boolean    @default(false)
  deletedAt         DateTime?
  createdAt         DateTime   @default(now())

  listing           Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, displayOrder])
  @@index([mediaType, deletedAt])
}

model Project {
  id                    String              @id @default(cuid())
  slug                  String              @unique
  status                ListingStatus       @default(DRAFT)
  developerOrgId        String
  provinceId            String
  districtId            String
  communeId             String?
  addressLine1          String
  latitude              Decimal             @db.Decimal(10, 7)
  longitude             Decimal             @db.Decimal(10, 7)
  tenureType            TenureType?
  completionDate        DateTime?
  launchDate            DateTime?
  minPriceUsd           Decimal?            @db.Decimal(14, 2)
  maxPriceUsd           Decimal?            @db.Decimal(14, 2)
  isFeatured            Boolean             @default(false)
  isVerified            Boolean             @default(false)
  publishedAt           DateTime?
  archivedAt            DateTime?
  deletedAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  developerOrg          Organization        @relation(fields: [developerOrgId], references: [id], onDelete: Restrict)
  province              Province            @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  district              District            @relation(fields: [districtId], references: [id], onDelete: Restrict)
  commune               Commune?            @relation(fields: [communeId], references: [id], onDelete: SetNull)
  translations          ProjectTranslation[]
  media                 ProjectMedia[]
  unitTypes             ProjectUnitType[]

  @@index([developerOrgId, status, deletedAt])
  @@index([provinceId, districtId, communeId])
  @@index([minPriceUsd, maxPriceUsd])
  @@index([publishedAt])
}

model ProjectTranslation {
  id               String      @id @default(cuid())
  projectId        String
  locale           LocaleCode
  name             String
  tagline          String?
  description      String
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([locale, name])
}

model ProjectUnitType {
  id                String      @id @default(cuid())
  projectId         String
  code              String
  bedrooms          Int?
  bathrooms         Int?
  sizeSqm           Decimal?    @db.Decimal(12, 2)
  minPriceUsd       Decimal?    @db.Decimal(14, 2)
  maxPriceUsd       Decimal?    @db.Decimal(14, 2)
  availableUnits    Int?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([bedrooms, bathrooms])
}

model ProjectMedia {
  id                String      @id @default(cuid())
  projectId         String
  mediaType         MediaType
  storageKey        String      @unique
  publicUrl         String
  mimeType          String?
  width             Int?
  height            Int?
  fileSizeBytes     BigInt?
  displayOrder      Int         @default(0)
  isCover           Boolean     @default(false)
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())

  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, displayOrder])
}

model Inquiry {
  id                  String         @id @default(cuid())
  listingId           String?
  projectId           String?
  createdById         String?
  assignedToId        String?
  source              InquirySource
  status              InquiryStatus  @default(NEW)
  name                String
  email               String?
  phoneE164           String?
  message             String?
  moveInDate          DateTime?
  budgetMinUsd        Decimal?       @db.Decimal(14, 2)
  budgetMaxUsd        Decimal?       @db.Decimal(14, 2)
  preferredLocale     LocaleCode     @default(EN)
  isSpam              Boolean        @default(false)
  spamScore           Decimal?       @db.Decimal(5, 2)
  contactedAt         DateTime?
  closedAt            DateTime?
  deletedAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  listing             Listing?       @relation(fields: [listingId], references: [id], onDelete: SetNull)
  project             Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy           User?          @relation("InquiryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo          User?          @relation("InquiryAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  messageThreads      MessageThread[]

  @@index([status, createdAt])
  @@index([listingId, status])
  @@index([projectId, status])
  @@index([assignedToId, status])
  @@index([isSpam, spamScore])
}

model SavedListing {
  id                String      @id @default(cuid())
  userId            String
  listingId         String
  createdAt         DateTime    @default(now())

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing           Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
}

model SearchAlert {
  id                String      @id @default(cuid())
  userId            String
  savedSearchId     String?
  name              String
  locale            LocaleCode  @default(EN)
  listingType       ListingType?
  propertyTypes     PropertyType[]
  provinceId        String?
  districtId        String?
  minPriceUsd       Decimal?    @db.Decimal(14, 2)
  maxPriceUsd       Decimal?    @db.Decimal(14, 2)
  minBedrooms       Int?
  maxBedrooms       Int?
  frequencyMinutes  Int         @default(1440)
  isActive          Boolean     @default(true)
  lastSentAt        DateTime?
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedSearch       SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@index([provinceId, districtId, isActive])
}

model SavedSearch {
  id                String      @id @default(cuid())
  userId            String
  name              String
  locale            LocaleCode  @default(EN)
  listingType       ListingType?
  propertyTypes     PropertyType[]
  provinceId        String?
  districtId        String?
  minPriceUsd       Decimal?    @db.Decimal(14, 2)
  maxPriceUsd       Decimal?    @db.Decimal(14, 2)
  minBedrooms       Int?
  maxBedrooms       Int?
  isActive          Boolean     @default(true)
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts            SearchAlert[]

  @@index([userId, isActive])
  @@index([provinceId, districtId, isActive])
}

model ViewingRequest {
  id                String               @id @default(cuid())
  listingId         String
  requesterId       String
  assignedAgentId   String?
  requestedAt       DateTime
  status            ViewingRequestStatus @default(PENDING)
  note              String?
  canceledReason    String?
  confirmedAt       DateTime?
  completedAt       DateTime?
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  listing           Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requester         User                 @relation("ViewingRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  assignedAgent     User?                @relation("ViewingAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)

  @@index([listingId, status, requestedAt])
  @@index([requesterId, status, requestedAt])
  @@index([assignedAgentId, status, requestedAt])
}

model MessageThread {
  id                String               @id @default(cuid())
  listingId         String?
  inquiryId         String?
  participantAId    String
  participantBId    String
  status            MessageThreadStatus  @default(OPEN)
  lastMessageAt     DateTime?
  archivedAt        DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  listing           Listing?             @relation(fields: [listingId], references: [id], onDelete: SetNull)
  inquiry           Inquiry?             @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  participantA      User                 @relation("ThreadParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB      User                 @relation("ThreadParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  messages          Message[]

  @@index([participantAId, status, updatedAt])
  @@index([participantBId, status, updatedAt])
  @@index([listingId, updatedAt])
}

model Message {
  id                String      @id @default(cuid())
  threadId          String
  senderId          String
  body              String
  isSystem          Boolean     @default(false)
  readAt            DateTime?
  deletedAt         DateTime?
  createdAt         DateTime    @default(now())

  thread            MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender            User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderId, createdAt])
}

model CmsArticle {
  id                String         @id @default(cuid())
  slug              String         @unique
  status            ArticleStatus  @default(DRAFT)
  category          String
  coverImageUrl     String?
  canonicalUrl      String
  publishedAt       DateTime?
  archivedAt        DateTime?
  deletedAt         DateTime?
  createdById       String
  updatedById       String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  createdBy         User           @relation("ArticleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User           @relation("ArticleUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  translations      CmsArticleTranslation[]

  @@index([status, publishedAt])
  @@index([category, status])
}

model CmsArticleTranslation {
  id                String      @id @default(cuid())
  articleId         String
  locale            LocaleCode
  title             String
  excerpt           String?
  body              String
  seoTitle          String?
  seoDescription    String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  article           CmsArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale, title])
}

model ModerationAction {
  id                String              @id @default(cuid())
  listingId         String
  moderatorId       String
  decision          ModerationDecision
  reasonCode        String?
  notes             String?
  createdAt         DateTime            @default(now())

  listing           Listing             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  moderator         User                @relation(fields: [moderatorId], references: [id], onDelete: Restrict)

  @@index([listingId, createdAt])
  @@index([moderatorId, createdAt])
}

model VerificationRequest {
  id                String              @id @default(cuid())
  userId            String?
  organizationId    String?
  requestedType     String
  documentStorageKey String?
  status            VerificationStatus  @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user              User?               @relation("VerificationRequestUser", fields: [userId], references: [id], onDelete: SetNull)
  organization      Organization?       @relation("VerificationRequestOrganization", fields: [organizationId], references: [id], onDelete: SetNull)
  reviewedBy        User?               @relation("VerificationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId])
  @@index([organizationId])
}

model CurrencyRate {
  id                String     @id @default(cuid())
  baseCode          String
  quoteCode         String
  rate              Decimal    @db.Decimal(18, 8)
  asOfDate          DateTime
  source            String?
  createdAt         DateTime   @default(now())

  @@unique([baseCode, quoteCode, asOfDate])
  @@index([quoteCode, asOfDate])
}

model AuditLog {
  id                String          @id @default(cuid())
  actorType         AuditActorType
  actorUserId       String?
  actorLabel        String?
  action            String
  entityType        String
  entityId          String
  severity          AuditSeverity   @default(INFO)
  ipAddress         String?
  userAgent         String?
  beforeJson        Json?
  afterJson         Json?
  metadataJson      Json?
  createdAt         DateTime        @default(now())

  actorUser         User?           @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([severity, createdAt])
}
